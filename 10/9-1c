#include<stdio.h>
int main(void){
    int a = 3,b = 5, c;
    double d = 0.5, e = -2.0, f;
    c = a + b;
    f = d + e;
    printf("a + b = %d, d + e = %f\n", c, f);
    printf("a = %a, &a = %p\n", a, &a);
    printf("b = %a, &b = %p\n", b, &b);
    printf("c = %a, &c = %p\n", c, &c);
    printf("d = %a, &c = %p\n", d, &d);
    printf("e = %a, &e = %p\n", e, &e);
    printf("f = %f, &f = %p\n", f, &f);
    return 0;
}